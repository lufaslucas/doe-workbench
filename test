#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "$0")" && pwd)"
export R_LIBS_USER="$ROOT_DIR/.Rlibs${R_LIBS_USER:+:$R_LIBS_USER}"
export NOT_CRAN="${NOT_CRAN:-true}"

if [[ $# -eq 0 ]]; then
  exec R -q -e "testthat::test_dir('tests/testthat', reporter='summary')"
fi

TARGET="$1"

if [[ -f "$ROOT_DIR/$TARGET" ]]; then
  exec R -q -e "testthat::test_file('$TARGET')"
fi

if [[ -f "$ROOT_DIR/tests/testthat/$TARGET" ]]; then
  exec R -q -e "testthat::test_file('tests/testthat/$TARGET')"
fi

echo "Usage:"
echo "  ./test"
echo "  ./test tests/testthat/test_state_management.R"
echo "  ./test test_state_management.R"
exit 1
